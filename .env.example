# 项目配置
PROJECT_NAME=music_ai
DEBUG=false

# GPU配置
USE_GPU=true
GPU_MEMORY_FRACTION=0.8

# 模型配置
VOICE_CLONE_MODE=fish_speech
MUSIC_GEN_MODEL=ace_step

# API配置
API_HOST=0.0.0.0
API_PORT=8000

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost/music_ai

# 文件路径
DATA_DIR=./data
MODELS_DIR=./models
